          }
        ]
      ]
    },
    "Build Candidate Slots": {
      "main": [
        [
          {
            "node": "Send Candidate Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Candidate Email": {
      "main": [
        [
          {
            "node": "Create Calendar Event",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create Calendar Event": {
      "main": [
        [
          {
            "node": "Insert Session Row",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Insert Session Row": {
      "main": [
        [
          {
            "node": "Start Training Cadence",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Start Training Cadence": {
      "main": [
        [
          {
            "node": "Update Client Status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Update Client Status": {
      "main": [
        [
          {
            "node": "Label Gmail",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {},
  "id": "DOM_Scheduling_Orchestrator",
  "versionId": "DOM_Scheduling_Orchestrator_v1"
}
